# === AppNext login ===
APPNEXT_REDE=teashop
APPNEXT_USER=openmall.palmas@teashop.com.br
APPNEXT_PASS=***

# === Drive / rclone ===
DRIVE_REMOTE=GDRIVE:
DRIVE_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DRIVE_FILE_NAME=importacaoA.xlsx

# === Datas (dd/mm/aaaa). DATA_FIM vazio => hoje ===
DATA_INICIO=01/06/2025
DATA_FIM=

# === Modelo do Excel ===
TEMPLATE_XLSX=importacaoA.xlsx
TEMPLATE_HEADER_ROW=2

# === (Opcional) Forçar loja pelo ID no fallback ===
APPNEXT_LOJA_ID_DESTINO=

# === (Opcional) Incluir token OAuth OU Service Account para rclone ===
# RCLONE_TOKEN é um JSON (token/refresh) obtido do "rclone config" (remoto GDRIVE).
# RCLONE_CONFIG_GDRIVE_SERVICE_ACCOUNT_FILE deve conter o JSON da SA em BASE64.
RCLONE_TOKEN=
RCLONE_CONFIG_GDRIVE_SERVICE_ACCOUNT_FILE=
